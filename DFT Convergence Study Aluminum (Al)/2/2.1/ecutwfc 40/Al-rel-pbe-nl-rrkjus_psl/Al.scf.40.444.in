&CONTROL
    calculation = 'scf'
    restart_mode = 'from_scratch'
    prefix = 'Al'
    pseudo_dir = '../pseudo'
    outdir = './temp'
/
&SYSTEM
    ibrav = 2
    celldm(1) = 10.2
    nat = 1
    ntyp = 1
    ecutwfc = 40.0
    noncolin = .true.
    lspinorb = .true.
    occupations = 'smearing'
    smearing = 'mv'
    degauss = 0.02
/
&ELECTRONS
    conv_thr = 1e-6
    mixing_beta = 0.7
/
ATOMIC_SPECIES
Al  26.98  Al.rel-pbe-nl-rrkjus_psl.1.0.0.UPF
ATOMIC_POSITIONS alat
Al 0.00 0.00 0.00
K_POINTS automatic
4 4 4 0 0 0
