&CONTROL
    calculation = 'scf'
    restart_mode = 'from_scratch'
    prefix = 'Al'
    pseudo_dir = '<PSEUDO_DIR>'
    outdir = './temp'
/
&SYSTEM
    ibrav = 2
    celldm(1) = 10.2
    nat = 1
    ntyp = 1
    ecutwfc = 60.0
    noncolin = <NONCOLIN>
    lspinorb = <LSPINORB>
    occupations = 'smearing'
    smearing = 'mv'
    degauss = 0.02
/
&ELECTRONS
    conv_thr = 1e-6
    mixing_beta = 0.7
/
ATOMIC_SPECIES
Al  26.98  <PSEUDO>
ATOMIC_POSITIONS alat
Al 0.00 0.00 0.00
K_POINTS automatic
<KPOINTS>
